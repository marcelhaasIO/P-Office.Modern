{
  "name": "p-office-modern",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @po/db db:generate",
    "db:migrate": "pnpm --filter @po/db db:migrate",
    "db:migrate:deploy": "pnpm --filter @po/db db:migrate:deploy",
    "db:migrate:status": "pnpm --filter @po/db db:migrate:status",
    "db:seed": "pnpm --filter @po/db db:seed",
    "e2e": "pnpm --filter @po/e2e test"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "5.7.2"
  }
}
