{
  "name": "p-office-modern",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:generate": "corepack pnpm --filter @po/db db:generate",
    "db:migrate": "corepack pnpm --filter @po/db db:migrate",
    "db:migrate:deploy": "corepack pnpm --filter @po/db db:migrate:deploy",
    "db:migrate:status": "corepack pnpm --filter @po/db db:migrate:status",
    "db:seed": "corepack pnpm --filter @po/db db:seed",
    "e2e": "corepack pnpm --filter @po/e2e test"
  },
  "dependencies": {
    "next": "16.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "5.7.2"
  }
}
